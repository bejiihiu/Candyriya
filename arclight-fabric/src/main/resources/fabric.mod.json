{
  "id": "arclight",
  "version": "${version}",
  "schemaVersion": 1,
  "name": "Candyriya Mod",
  "authors": [
    "bejiihiu"
  ],
  "description": "Candyriya bukkit layer for Fabric (based on Arclight)",
  "license": "GNU GENERAL PUBLIC LICENSE Version 3",
  "environment": "server",
  "mixins": [
    "mixins.arclight.fabric.json",
    "mixins.arclight.core.json",
    "mixins.arclight.bukkit.json",
    "mixins.arclight.vanilla.json",
    "mixins.arclight.impl.optimization.json"
  ],
  "depends": {
    "fabricloader": ">=0.16",
    "fabric-permissions-api-v0": ">=0.3"
  },
  "entrypoints": {
    "main": [
      "io.izzel.arclight.fabric.ArclightModEntrypoint"
    ],
    "arclight_boot": [
      "io.izzel.arclight.fabric.boot.FabricBootstrap"
    ]
  }
